{
  "entities": {
    "User": {
      "title": "User",
      "description": "User metadata and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "Task details and assignment",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string", "description": "UID of the user" },
        "assignedToEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "isRecurring": { "type": "boolean" },
        "recurrenceInterval": { "type": "string", "enum": ["daily", "weekly", "monthly", "none"] },
        "completionNote": { "type": "string" },
        "isArchived": { "type": "boolean" },
        "archivedAt": { "type": "string", "format": "date-time" },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "assignedTo", "status"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Vehicle information and inspection/insurance details",
      "type": "object",
      "properties": {
        "plateNo": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "modelYear": { "type": "string" },
        "registrationSerialNo": { "type": "string" },
        "owner": { "type": "string" },
        "firstInspectionDate": { "type": "string", "format": "date" },
        "firstInspectionEnteredBy": { "type": "string" },
        "firstInspectionApproved": { "type": "boolean" },
        "repeatInspectionDate": { "type": "string", "format": "date" },
        "repeatInspectionReason": { "type": "string" },
        "insurancePolicyDate": { "type": "string", "format": "date" },
        "insuranceAmount": { "type": "number" },
        "kaskoDate": { "type": "string", "format": "date" },
        "kaskoAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["plateNo", "brand", "model"]
    },
    "TaxCalendarSettings": {
      "title": "TaxCalendarSettings",
      "description": "Admin settings for the tax calendar",
      "type": "object",
      "properties": {
        "selectedTaxTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["selectedTaxTypes"]
    },
    "TaxSubmission": {
      "title": "TaxSubmission",
      "description": "User's tax submission details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taxType": { "type": "string" },
        "period": { "type": "string", "description": "e.g., 2026-03" },
        "isSubmitted": { "type": "boolean" },
        "amount": { "type": "number" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "taxType", "period", "isSubmitted"]
    },
    "TaxCalendarEntry": {
      "title": "TaxCalendarEntry",
      "description": "A single entry from the official tax calendar",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "declarationDeadline": { "type": "string", "format": "date" },
        "paymentDeadline": { "type": "string", "format": "date" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "declarationDeadline", "paymentDeadline"]
    },
    "Company": {
      "title": "Company",
      "description": "Company identity information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "taxNo": { "type": "string" },
        "sgkNo": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "signatory": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "taxNo", "name"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks collection"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicles collection"
    },
    "/settings/taxCalendar": {
      "schema": "TaxCalendarSettings",
      "description": "Tax calendar global settings"
    },
    "/taxSubmissions/{submissionId}": {
      "schema": "TaxSubmission",
      "description": "User tax submissions"
    },
    "/taxCalendarEntries/{entryId}": {
      "schema": "TaxCalendarEntry",
      "description": "Fetched tax calendar entries"
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Company identity cards"
    }
  }
}
